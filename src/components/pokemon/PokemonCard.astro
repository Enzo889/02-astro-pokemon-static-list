---
interface Props {
  name: string;
  url: string;
  isBig?: boolean;
}

const { name, url, isBig = false } = Astro.props;

const id = url.split("/").at(-2) ?? "1";
const ArtWork = `https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/other/official-artwork/${id}.png`;
---

<a
  class:list={[
    `rounded flex flex-col justify-center items-center p-2 text-center `,
    {
      border: !isBig,
    },
  ]}
  href={`/pokemons/${name}`}
>
  <img
    transition:name=`${name}-image`
    class:list={[
      {
        "w-32 h-32": isBig,
        "w-22 h-22": !isBig,
      },
    ]}
    src={ArtWork}
    alt={name}
  />
  <span
    class:list={[
      "capitalize",
      {
        "text-4xl text-blue-300": isBig,
      },
    ]}>#{id} {name}</span
  >
</a>
