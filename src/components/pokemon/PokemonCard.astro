---
interface Props {
  name: string;
  url: string;
  isBig?: boolean;
}

const { name, url, isBig = false } = Astro.props;

const id = url.split("/").at(-2) ?? "1";
const ArtWork = `https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/other/official-artwork/${id}.png`;
---

<a
  class:list={[
    `flex flex-col justify-center items-center p-4 text-center hover:bg-gray-200 transition-colors`,
    {
      "retro-dialog": !isBig,
    },
  ]}
  href={`/pokemons/${name}`}
>
  <img
    transition:name=`${name}-image`
    class:list={[
      {
        "w-42 h-42": isBig,
        "w-26 h-26": !isBig,
      },
    ]}
    src={ArtWork}
    alt={name}
  />
  <span
    class:list={[
      "uppercase mt-2",
      {
        "text-3xl lg:text-5xl": isBig,
        "text-xs sm:text-sm": !isBig
      },
    ]}>#{id} {name}</span
  >
</a>
