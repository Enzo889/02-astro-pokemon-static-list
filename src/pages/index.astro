---
import Counter from "../components/Counter";
import ClasicGameNav from "../components/shared/ClasicGameNav.astro";
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Pokémon static list | Home">
  <!-- Hero Section -->
  <section class="flex flex-col items-center justify-center mb-4 relative mt-4">
    <h1
      class="text-4xl md:text-6xl uppercase font-bold text-center tracking-widest text-red-600 mb-2"
      style="text-shadow: 4px 4px 0px black;"
    >
      POKÉMON
    </h1>
    <h2
      class="text-xl md:text-3xl uppercase font-bold text-center mt-2 tracking-widest mb-8 text-black"
    >
      RED VERSION
    </h2>
    <ClasicGameNav />
  </section>

  <div class="retro-dialog mb-8 p-2 aspect-video flex justify-center bg-black">
    <video
      controls
      autoplay
      muted
      transition:persist="media-player"
      class="w-full h-full aspect-video object-contain"
    >
      <source
        src="https://archive.org/download/PokemonRed_209/PokemonRed_209_HQ_part01.mp4"
        type="video/mp4"
      />
    </video>
  </div>

  <div class="retro-dialog mb-8 text-xs sm:text-base leading-relaxed">
    <p class="mb-4">
      Welcome to this Astro learning project! Below you'll find a Counter component and above is a Video player.
    </p>
    <p class="mb-4">
      <span class="text-red-600">Why are they here?</span> This page serves as a live demonstration of <strong>Astro Islands</strong> and <strong>View Transitions</strong>.
    </p>
    <ul class="list-disc list-inside flex flex-col gap-2">
      <li><strong>The Video</strong> uses <code class="bg-gray-200 px-1 text-black">transition:persist</code> to keep playing without interruption when you navigate to other pages.</li>
      <li><strong>The Counter</strong> is an interactive SolidJS island that loads only when visible using <code class="bg-gray-200 px-1 text-black">client:visible</code>, and its state is saved across navigations using <code class="bg-gray-200 px-1 text-black">transition:persist</code>.</li>
    </ul>
  </div>

  <Counter
    client:visible
    transition:persist="counter"
    transition:persist-props
    initialValue={30}
  />
</MainLayout>
