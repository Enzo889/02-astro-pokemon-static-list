---
import type { GetStaticPaths } from "astro";
import PokemonCard from "../../components/pokemon/PokemonCard.astro";
import type { PokemonListResponse } from "../../interfaces/pokemon-list.response";
import MainLayout from "../../layouts/MainLayout.astro";

export const getStaticPaths = (async ({ paginate }) => {
  const res = await fetch("https://pokeapi.co/api/v2/pokemon?limit=151");
  const { results } = (await res.json()) as PokemonListResponse;

  return paginate(results, { pageSize: 20 });
}) satisfies GetStaticPaths;

const { page } = Astro.props;
---

<MainLayout
  title="Pokémon static list | Home"
  description="pokemon list with pagination"
>
  <h1>Pokemon List</h1>
  <hr />
  <section
    aria-label="pokemon list"
    class="grid grid-cols-1 sm:grid-cols-4 md:grid-cols-5 mt-5 gap-4"
  >
    {page.data.map((data) => <PokemonCard name={data.name} url={data.url} />)}
  </section>

  <section class="flex mt-10 gap-2 items-center w-full">
    <a
      class:list={[
        "btn",
        {
          disabled: !page.url.prev,
        },
      ]}
      href={page.url.prev}>Previous</a
    >
    <a
      class:list={[
        "btn",
        {
          disabled: !page.url.next,
        },
      ]}
      href={page.url.next}>Next</a
    >
    <div class="flex flex-1"></div>
    <span class="text-xl font-bold">page {page.currentPage}</span>
  </section>
</MainLayout>

<style>
  .btn {
    background-color: #3b82f6;
    color: white;
    padding: 0.5rem 1rem;
    border-radius: 0.5rem;
    text-decoration: none;
    transition: background-color 0.3s ease;
  }

  .btn:hover {
    background-color: #2563eb;
  }

  .disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
</style>
